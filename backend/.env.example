# Copy to `.env` in this folder (`cp .env.example .env`) and adjust values.
# `backend/.env` is gitignored. Docker Compose loads it for the `api` service when present.
#
# Docker Compose note: `docker-compose.yml` sets DATABASE_URL, TRUST_PROXY, SESSION_COOKIE_SECURE,
# CORS_ORIGIN, and PUPPETEER_EXECUTABLE_PATH on the `api` service; those keys win over the same
# names in `backend/.env`. Use this file mainly for secrets (SESSION_SECRET, ADMIN_*, etc.) when
# running the stack with Compose. For local `node` without Docker, all variables here apply.

# --- Database (local Node: use localhost; Docker Compose overrides DATABASE_URL in compose file)
DATABASE_URL=postgresql://reactwork:reactwork@localhost:5432/reactworkplace

# --- Server
PORT=4000

# --- Trust proxy (set to 1 behind nginx, Cloudflare, or any reverse proxy)
TRUST_PROXY=1

# --- Session (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string
# Optional alias read by the app if SESSION_SECRET is unset:
# JWT_SECRET=

# HTTPS site: must be "true" so the session cookie is Secure (see SESSION_COOKIE_SECURE in code)
SESSION_COOKIE_SECURE=true

# Comma-separated browser origins allowed for credentialed CORS (e.g. your Vite dev server and public URL).
# If unset, the app uses built-in localhost defaults — set this in production.
# CORS_ORIGIN=https://react.kct.ac.in
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://react.kct.ac.in

# --- Primary admin (env login) and optional extra admins in DB
ADMIN_EMAIL=react@kct.ac.in
ADMIN_PASSWORD=change-me

# --- Errors (set to 1 only for debugging; avoid in production)
# API_VERBOSE_ERRORS=1

# --- PDF / OD letters (Dockerfile sets chromium path; override if needed)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# CHROME_PATH=
